{
  "openapi": "3.0.3",
  "info": {
    "title": "Web Monitor Interface API",
    "version": "1.0.0",
    "description": "Minecraft Forge 模组 REST API，用于监控服务器状态、方块、实体、玩家、能力和事件。默认监听 `127.0.0.1:18080`。\n\n## 认证\n\n- 集成服务器/单人游戏：无需 key。\n- 专用服务器：需要 `Authorization: Bearer <key>` 请求头。\n- 限流：每个有效 key 每分钟 120 次（可配置）。\n\n## WebSocket\n\n- 端点：`ws://host:18080/ws`\n- 在 HTTP Upgrade 阶段使用相同的 Bearer 认证。\n- 支持动作：`subscribe`、`unsubscribe`、`ping`、`publish`。\n- 事件：`chat.public`、`player.join`、`player.quit`。\n\n## 响应格式\n\n所有响应使用以下封装：\n```json\n{\"code\": 0, \"msg\": \"ok\", \"data\": {}, \"trace_id\": \"uuid\", \"server_tick\": 123}\n```\n\n错误码：`1001` 参数错误、`1002` 未找到、`2001` 未授权、`2002` 禁止操作、`4001` 限流、`3002` 内部错误。"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:18080",
      "description": "默认本地服务器"
    }
  ],
  "paths": {
    "/api/v1/status": {
      "get": {
        "summary": "服务器状态",
        "description": "返回服务器、玩家、Web 服务和认证状态。",
        "tags": ["服务器"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "服务器状态",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/StatusData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/tps": {
      "get": {
        "summary": "TPS 和 Tick 指标",
        "tags": ["服务器"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "TPS 数据",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/TpsData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/worlds": {
      "get": {
        "summary": "列出已加载维度",
        "tags": ["世界"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "世界列表",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/WorldListData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/events/catalog": {
      "get": {
        "summary": "事件目录",
        "description": "列出可订阅的 WebSocket 事件及其描述。",
        "tags": ["事件"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "事件目录",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/EventCatalogData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blockstate": {
      "get": {
        "summary": "获取方块状态属性",
        "description": "返回单个方块状态属性的值。",
        "tags": ["方块"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "$ref": "#/components/parameters/X" },
          { "$ref": "#/components/parameters/Y" },
          { "$ref": "#/components/parameters/Z" },
          { "$ref": "#/components/parameters/Key" }
        ],
        "responses": {
          "200": {
            "description": "方块属性",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/BlockPropertyData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blockentity": {
      "get": {
        "summary": "获取方块实体 NBT",
        "description": "返回方块实体的结构化 NBT。可选通过点分隔的 NBT 路径获取子值。",
        "tags": ["方块"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "$ref": "#/components/parameters/X" },
          { "$ref": "#/components/parameters/Y" },
          { "$ref": "#/components/parameters/Z" },
          { "$ref": "#/components/parameters/Path" }
        ],
        "responses": {
          "200": {
            "description": "方块实体 NBT",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "oneOf": [
                            { "$ref": "#/components/schemas/BlockEntityFullNbtData" },
                            { "$ref": "#/components/schemas/BlockEntityPathNbtData" }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blockentity/snbt": {
      "get": {
        "summary": "获取方块实体 SNBT",
        "description": "返回方块实体的 SNBT 字符串。可选通过点分隔的 NBT 路径获取子值。",
        "tags": ["方块"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "$ref": "#/components/parameters/X" },
          { "$ref": "#/components/parameters/Y" },
          { "$ref": "#/components/parameters/Z" },
          { "$ref": "#/components/parameters/Path" }
        ],
        "responses": {
          "200": {
            "description": "方块实体 SNBT",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "oneOf": [
                            { "$ref": "#/components/schemas/BlockEntityFullSnbtData" },
                            { "$ref": "#/components/schemas/BlockEntityPathSnbtData" }
                          ]
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blockentity/capability": {
      "get": {
        "summary": "获取方块实体能力快照",
        "description": "返回方块实体 Forge 能力（energy、items 或 fluid）的只读快照。",
        "tags": ["能力"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "$ref": "#/components/parameters/X" },
          { "$ref": "#/components/parameters/Y" },
          { "$ref": "#/components/parameters/Z" },
          { "$ref": "#/components/parameters/Cap" }
        ],
        "responses": {
          "200": {
            "description": "能力快照",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/CapabilitySnapshotData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/entity/{entityId}": {
      "get": {
        "summary": "按运行时 ID 获取实体",
        "tags": ["实体"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "$ref": "#/components/parameters/EntityId" }
        ],
        "responses": {
          "200": {
            "description": "实体详情",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/EntityData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/entity/{entityId}/capability": {
      "get": {
        "summary": "获取实体能力快照",
        "description": "返回实体 Forge 能力的只读快照。",
        "tags": ["能力"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "$ref": "#/components/parameters/EntityId" },
          { "$ref": "#/components/parameters/Cap" }
        ],
        "responses": {
          "200": {
            "description": "实体能力快照",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/CapabilitySnapshotData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/player/{uuidOrName}": {
      "get": {
        "summary": "获取在线玩家详情",
        "description": "返回玩家信息、背包和状态。接受 UUID 或玩家名称。",
        "tags": ["玩家"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "name": "uuidOrName", "in": "path", "required": true, "schema": { "type": "string" }, "description": "玩家 UUID 或显示名称" }
        ],
        "responses": {
          "200": {
            "description": "玩家详情",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/PlayerDetailData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/players": {
      "get": {
        "summary": "列出维度内玩家",
        "description": "返回指定维度内的所有在线玩家。",
        "tags": ["玩家"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" }
        ],
        "responses": {
          "200": {
            "description": "玩家列表",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/PlayerListData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/entities/aabb": {
      "get": {
        "summary": "查询 AABB 内实体",
        "description": "返回轴对齐包围盒内的实体。可选类型过滤和限制（最大 1000）。",
        "tags": ["实体"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "$ref": "#/components/parameters/MinX" },
          { "$ref": "#/components/parameters/MinY" },
          { "$ref": "#/components/parameters/MinZ" },
          { "$ref": "#/components/parameters/MaxX" },
          { "$ref": "#/components/parameters/MaxY" },
          { "$ref": "#/components/parameters/MaxZ" },
          { "$ref": "#/components/parameters/EntityType" },
          { "$ref": "#/components/parameters/Limit" }
        ],
        "responses": {
          "200": {
            "description": "AABB 查询结果",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/AabbResultData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blocks": {
      "post": {
        "summary": "批量方块查询",
        "description": "通过 positions 数组或 region 区域批量查询方块。可选 body 中 `filter` 或查询参数 `?type=` 过滤方块 ID。最多扫描 4096 个位置，最多返回 1000 个方块。",
        "tags": ["方块", "批量"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" },
          { "name": "type", "in": "query", "required": false, "schema": { "type": "string" }, "description": "方块 ID 过滤器（如 minecraft:chest）。覆盖 body 中的 filter。" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/BatchRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "批量查询结果",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/BatchResultData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blockstates": {
      "post": {
        "summary": "批量方块状态查询",
        "description": "通过 positions 数组批量查询方块状态。返回每个位置的状态。",
        "tags": ["方块", "批量"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PositionsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "批量状态结果",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/BatchStateResultData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blockentities": {
      "post": {
        "summary": "批量方块实体 NBT 查询",
        "description": "通过 positions 数组批量查询方块实体的结构化 NBT。",
        "tags": ["方块", "批量"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PositionsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "批量实体 NBT 结果",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/BatchEntityNbtResultData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blockentities/snbt": {
      "post": {
        "summary": "批量方块实体 SNBT 查询",
        "description": "通过 positions 数组批量查询方块实体的 SNBT 字符串。",
        "tags": ["方块", "批量"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PositionsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "批量实体 SNBT 结果",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/BatchEntitySnbtResultData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/{dim}/blockentity/capabilities": {
      "post": {
        "summary": "批量方块实体能力查询",
        "description": "通过 positions 数组批量查询方块实体的能力可用性列表。",
        "tags": ["能力", "批量"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/Dim" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PositionsRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "批量能力结果",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiResponse" },
                    {
                      "type": "object",
                      "properties": {
                        "data": { "$ref": "#/components/schemas/BatchCapabilityResultData" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "通过 Authorization: Bearer <key> 传递 API key"
      }
    },
    "parameters": {
      "Dim": { "name": "dim", "in": "path", "required": true, "schema": { "type": "string" }, "description": "维度标识符，如 minecraft:overworld、minecraft:the_nether、minecraft:the_end 或自定义维度资源位置" },
      "X": { "name": "x", "in": "query", "required": true, "schema": { "type": "integer" }, "description": "方块 X 坐标" },
      "Y": { "name": "y", "in": "query", "required": true, "schema": { "type": "integer" }, "description": "方块 Y 坐标" },
      "Z": { "name": "z", "in": "query", "required": true, "schema": { "type": "integer" }, "description": "方块 Z 坐标" },
      "Key": { "name": "key", "in": "query", "required": true, "schema": { "type": "string" }, "description": "方块状态属性名称" },
      "Path": { "name": "path", "in": "query", "required": false, "schema": { "type": "string" }, "description": "点分隔的 NBT 路径（如 \"Items.0.tag\"）" },
      "Cap": { "name": "cap", "in": "query", "required": true, "schema": { "type": "string" }, "description": "能力名称：energy、items 或 fluid" },
      "EntityId": { "name": "entityId", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "运行时实体 ID" },
      "MinX": { "name": "minX", "in": "query", "required": true, "schema": { "type": "number", "format": "double" } },
      "MinY": { "name": "minY", "in": "query", "required": true, "schema": { "type": "number", "format": "double" } },
      "MinZ": { "name": "minZ", "in": "query", "required": true, "schema": { "type": "number", "format": "double" } },
      "MaxX": { "name": "maxX", "in": "query", "required": true, "schema": { "type": "number", "format": "double" } },
      "MaxY": { "name": "maxY", "in": "query", "required": true, "schema": { "type": "number", "format": "double" } },
      "MaxZ": { "name": "maxZ", "in": "query", "required": true, "schema": { "type": "number", "format": "double" } },
      "EntityType": { "name": "type", "in": "query", "required": false, "schema": { "type": "string" }, "description": "实体类型过滤器（如 minecraft:pig）" },
      "Limit": { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "maximum": 1000, "default": 50 }, "description": "最大返回实体数（上限 1000）" }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "required": ["code", "msg", "trace_id", "server_tick"],
        "properties": {
          "code": { "type": "integer", "description": "0 = 成功，非零 = 错误码" },
          "msg": { "type": "string", "description": "成功时为 ok，失败时为错误信息" },
          "data": { "description": "响应数据（仅在成功时存在）" },
          "trace_id": { "type": "string", "format": "uuid", "description": "唯一请求追踪 ID" },
          "server_tick": { "type": "integer", "description": "响应时的服务器 tick 计数" }
        }
      },
      "StatusData": {
        "type": "object",
        "properties": {
          "running": { "type": "boolean" },
          "players": { "type": "integer" },
          "max_players": { "type": "integer" },
          "motd": { "type": "string" },
          "version": { "type": "string" },
          "dedicated": { "type": "boolean" },
          "auth_required": { "type": "boolean" },
          "web_running": { "type": "boolean" },
          "web_port": { "type": "integer" }
        }
      },
      "TpsData": {
        "type": "object",
        "properties": {
          "tps": { "type": "number", "format": "double" },
          "average_tick_ms": { "type": "number", "format": "double" },
          "tick_count": { "type": "integer" }
        }
      },
      "WorldListData": {
        "type": "object",
        "properties": {
          "worlds": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/WorldEntry" }
          }
        }
      },
      "WorldEntry": {
        "type": "object",
        "properties": {
          "dimension": { "type": "string", "description": "维度资源位置" },
          "loaded_chunks": { "type": "integer" },
          "difficulty": { "type": "string" }
        }
      },
