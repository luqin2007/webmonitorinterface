{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "prepareRunClientCompile",
      "type": "shell",
      "command": "./gradlew prepareRunClientCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "prepareRunServerCompile",
      "type": "shell",
      "command": "./gradlew prepareRunServerCompile",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "runClientDebug",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "runClient",
        "--debug-jvm"
      ],
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "java",
        "pattern": {
          "regexp": "^(.+\\.java):(\\d+): (error|warning): (.+)$",
          "file": 1,
          "line": 2,
          "severity": 3,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Listening for transport dt_socket at address: 5005"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
